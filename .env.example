# Database
POSTGRES_DB=support
POSTGRES_USER=support_user
POSTGRES_PASSWORD=change_me_strong

# OpenWebUI
WEBUI_SECRET_KEY=change_me_secret
WEBUI_API_KEY=change_me_webui_api_key

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# Model storage + registries for download/check scripts
MODELS_ROOT_DIR=./models
LLM_MODEL_DIR=./models/llm
VISION_MODEL_DIR=./models/vision/qwen3-vl-2b-instruct
EMBEDDING_MODEL_DIR=./models/embeddings/bge-m3
RERANKER_MODEL_DIR=./models/reranker/bge-reranker-v2-m3
OCR_MODEL_ROOT_DIR=./models/ocr

LLM_HF_REPO=bartowski/Qwen2.5-7B-Instruct-GGUF
VISION_HF_REPO=Qwen/Qwen3-VL-2B-Instruct
EMBEDDING_HF_REPO=BAAI/bge-m3
RERANKER_HF_REPO=BAAI/bge-reranker-v2-m3

OCR_DET_URL=https://paddleocr.bj.bcebos.com/PP-OCRv4/chinese/ch_PP-OCRv4_det_infer.tar
OCR_REC_URL=https://paddleocr.bj.bcebos.com/PP-OCRv4/chinese/ch_PP-OCRv4_rec_infer.tar
OCR_CLS_URL=https://paddleocr.bj.bcebos.com/dygraph_v2.0/ch/ch_ppocr_mobile_v2.0_cls_infer.tar

DATA_INBOX_CSV_ANS_DOCS_DIR=./data/inbox/csv_ans_docs
DATA_INBOX_INTERNAL_REGULATIONS_DIR=./data/inbox/internal_regulations

# LLM server
LLM_MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLM_CTX_SIZE=8192
LLM_N_GPU_LAYERS=99
LLM_PARALLEL=2
LLM_THREADS=8
LLAMA_CPP_IMAGE=ghcr.io/ggerganov/llama.cpp:server-cuda-b4719

# Build/runtime GPU selection
# Allowed values: auto | cpu | cuda
SUPPORT_API_TORCH_DEVICE=cuda
# Allowed values: auto | cpu | cuda
INGEST_TORCH_DEVICE=cuda

# support-api runtime/deps
SUPPORT_API_BASE_IMAGE_REPO=cr.yandex/<registry_id>/rag-support-api-base
SUPPORT_API_DEPS_TAG=dev

# OS base images (APT слой)
SUPPORT_API_OS_BASE_IMAGE_REPO=cr.yandex/<registry_id>/rag-support-api-os-base
INGEST_OS_BASE_IMAGE_REPO=cr.yandex/<registry_id>/rag-ingest-os-base
SUPPORT_API_OS_TAG=latest
INGEST_OS_TAG=latest

# ingest deps
INGEST_BASE_IMAGE_REPO=cr.yandex/<registry_id>/rag-ingest-base
INGEST_DEPS_TAG=dev

# yandex registry auth helper
YC_REGISTRY_ID=<registry_id>
# Auto-run `yc container registry configure-docker` inside build_ingest_base.sh when IMAGE_REPO starts with cr.yandex/
YC_DOCKER_AUTH=1

# pip / wheelhouse
PIP_INDEX_URL=https://pypi.org/simple
PIP_FALLBACK_INDEX_URL=https://mirror.yandex.ru/mirrors/pypi/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=
PIP_MODE=auto
PIP_ONLINE_FALLBACK=1

# unified CUDA torch stack
PYTORCH_CUDA_INDEX_URL=https://download.pytorch.org/whl/cu128
TORCH_VERSION=2.10.0
TORCHVISION_VERSION=0.25.0
TORCHAUDIO_VERSION=2.10.0

# wheel target
TARGET_PLATFORM=manylinux2014_x86_64
TARGET_PYTHON_VERSION=311
TARGET_IMPLEMENTATION=cp
TARGET_ABI=cp311
# Allowed values: auto | cpu | cuda
EMBEDDING_DEVICE=cuda
# Allowed values: auto | cpu | cuda
RERANKER_DEVICE=cuda
# Allowed values: auto | cpu | cuda
INGEST_EMBEDDING_DEVICE=cuda
# Allowed values: auto | cpu | cuda
INGEST_RERANKER_DEVICE=cuda
# Allowed values: 0 (fallback to CPU) | 1 (strict fail-fast)
INGEST_EMBEDDING_DEVICE_STRICT=0

LOG_LEVEL=INFO

# Chunking profile: corpus A (CSV ANS docs)
CHUNK_SIZE_CSV_ANS_DOCS=1100
CHUNK_OVERLAP_CSV_ANS_DOCS=150
CHUNK_STRATEGY_CSV_ANS_DOCS=docs

# Chunking profile: corpus B (internal regulations)
CHUNK_SIZE_INTERNAL_REGULATIONS=700
CHUNK_OVERLAP_INTERNAL_REGULATIONS=160
CHUNK_STRATEGY_INTERNAL_REGULATIONS=regs

# RAG models
EMBEDDING_MODEL_PATH=/models/embeddings/bge-m3
RERANKER_MODEL_PATH=/models/reranker/bge-reranker-v2-m3

# Multimodal/OCR
# Allowed values: true | false
VISION_ENABLED=true
# Allowed values: true | false
VISION_INGEST_ENABLED=true
# Allowed values: ocr | vlm
VISION_RUNTIME_MODE=ocr
# Allowed values: ocr | vlm
VISION_INGEST_MODE=ocr
VISION_OCR_MODEL_ROOT=/models/ocr
VISION_OCR_LANG=ru
# Allowed values: auto | cpu | cuda
VISION_OCR_DEVICE=auto
# Allowed values: true | false
VISION_OCR_USE_ANGLE_CLS=true
# Allowed values: true | false
VISION_OCR_SHOW_LOG=false
VISION_MODEL_PATH=/models/vision/qwen3-vl-2b-instruct
# Allowed values: auto | cpu | cuda
VISION_MODEL_DEVICE=auto
# Allowed values: auto | float32 | float16 | bfloat16
VISION_MODEL_DTYPE=auto
VISION_MODEL_MAX_NEW_TOKENS=160
VISION_MODEL_PROMPT_RUNTIME=Опиши скриншот пользователя для службы поддержки. Если видны ошибки/коды/статусы — укажи их.
VISION_MODEL_PROMPT_INGEST=Кратко опиши изображение для индексации документации. Укажи важные надписи, элементы интерфейса и возможные коды ошибок.
