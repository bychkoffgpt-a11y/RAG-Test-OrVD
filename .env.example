POSTGRES_DB=support
POSTGRES_USER=support_user
POSTGRES_PASSWORD=change_me_strong

WEBUI_SECRET_KEY=change_me_secret
WEBUI_API_KEY=local-offline-key

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

LLM_MODEL_FILE=qwen2.5-7b-instruct-q4_k_m.gguf
LLM_CTX_SIZE=8192
LLM_N_GPU_LAYERS=99
LLM_PARALLEL=2
LLM_THREADS=8

LLAMA_CPP_IMAGE=ghcr.io/ggerganov/llama.cpp:server-cuda-b4719

# Опционально: контрольные суммы (SHA256) для валидации офлайн-артефактов
LLM_MODEL_SHA256=
EMBEDDING_MODEL_SHA256=
RERANKER_MODEL_SHA256=

LOG_LEVEL=INFO

# Параметры чанкинга для корпуса A (документация ЦСВ АНС)
CHUNK_SIZE_CSV_ANS_DOCS=1100
CHUNK_OVERLAP_CSV_ANS_DOCS=150
CHUNK_STRATEGY_CSV_ANS_DOCS=docs

# Параметры чанкинга для корпуса B (нормативные документы)
CHUNK_SIZE_INTERNAL_REGULATIONS=700
CHUNK_OVERLAP_INTERNAL_REGULATIONS=160
CHUNK_STRATEGY_INTERNAL_REGULATIONS=regs
