# syntax=docker/dockerfile:1.7
ARG SUPPORT_API_OS_BASE_IMAGE=python:3.11-slim
FROM ${SUPPORT_API_OS_BASE_IMAGE}

RUN set -euo pipefail; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      libreoffice \
      tesseract-ocr \
      tesseract-ocr-rus \
      poppler-utils; \
    rm -rf /var/lib/apt/lists/*
